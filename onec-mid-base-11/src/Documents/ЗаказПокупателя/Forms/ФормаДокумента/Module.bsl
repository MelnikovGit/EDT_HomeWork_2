
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// Добавляем элемент Контактное лицо  
	НовыйЭлемент = Элементы.Добавить("КонтактноеЛицо",Тип("ПолеФормы"),Элементы.ГруппаШапкаПраво);
	НовыйЭлемент.ПутьКДанным    = "Объект.КонтактноеЛицо";
	НовыйЭлемент.Вид            = ВидПоляФормы.ПолеВвода; 	
	
	//Добавляем новую группу и в нее реквизиты формы: Согласованная скидка и Команда "Перерасчет"
	
	НоваяГруппаФормы = Элементы.Добавить("ГруппаСкидкаИПересчет",Тип("ГруппаФормы"),Элементы.ГруппаШапкаЛево);
	НоваяГруппаФормы.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	НоваяГруппаФормы.Отображение         = ОтображениеОбычнойГруппы.Нет;
	НоваяГруппаФормы.ОтображатьЗаголовок = Ложь;
	НоваяГруппаФормы.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	
	НовыйЭлемент = Элементы.Добавить("СогласованнаяСкидка",Тип("ПолеФормы"),НоваяГруппаФормы);
	НовыйЭлемент.ПутьКДанным    = "Объект.СогласованнаяСкидка";
	НовыйЭлемент.Вид            = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.КнопкаОчистки = Истина; 
	НовыйЭлемент.КнопкаВыбора = Истина;
	НовыйЭлемент.УстановитьДействие("ПриИзменении","СогласованнаяСкидкаПриИзменении");
	
	НоваяКоманда = ЭтаФорма.Команды.Добавить("Перерасчет");  
	НоваяКоманда.Действие = "Перерасчет" ; 
	НоваяКнопка = Элементы.Добавить("Перерасчет", Тип("КнопкаФормы"), НоваяГруппаФормы) ; 
	
	НоваяКнопка.ИмяКоманды = "Перерасчет"; 
	
КонецПроцедуры

