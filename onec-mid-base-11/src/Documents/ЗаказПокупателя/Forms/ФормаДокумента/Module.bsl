#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	
	//КоэффициентСкидки = 1 - ТекущиеДанные.Скидка / 100;
	//ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки;
	
	// Добавляем код изменения при расчете 
	
	
	Если  ПревышениеСовместнойСкидкиБолее100Процентов(Объект.СогласованнаяСкидка,ТекущиеДанные.Скидка,ТекущиеДанные.НомерСтроки) Тогда
		
		ТекущиеДанные.Сумма = 0; 
		
	иначе  
		
		ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество*(1 - (Объект.СогласованнаяСкидка+ТекущиеДанные.Скидка)/100);
		
	КонецЕсли;
	
	РассчитатьСуммуДокумента();    
	
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры

&НаКлиенте

Функция ПревышениеСовместнойСкидкиБолее100Процентов(СогласованнаяСкидка,СкидкаПостроке,НомерСтроки)
	
	Более100Процентов = (СогласованнаяСкидка+СкидкаПостроке) >100;
	
	Если Более100Процентов Тогда
	
		 Сообщение = Новый СообщениеПользователю;
		 Сообщение.Текст = "Скидка более 100 процентов установлена сумма по строке " +НомерСтроки+" в  0!!!";
		 Сообщение.Сообщить();
	     Возврат Истина;  
		 
	КонецЕсли;
	
	Возврат Ложь;

КонецФункции 

&НаКлиенте

Процедура Перерасчет(Команда)
	
	ПерерасчетТабЧастиПоСкидке(Объект.Товары);
	ПерерасчетТабЧастиПоСкидке(Объект.Услуги);
	
	
КонецПроцедуры  

&НаКлиенте
Процедура ПерерасчетТабЧастиПоСкидке(ТабличнаяЧасть)
	
	Перем СтрокаТаблицы;
	
	Для каждого СтрокаТаблицы Из  ТабличнаяЧасть Цикл
		
		РассчитатьСуммуСтроки(СтрокаТаблицы);
		
	КонецЦикла;	
	
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура СогласованнаяСкидкаПриИзменении(Элемент)
	ТекстВопроса = "Пересчитать согласно скидки табличную часть документа?"; 
	
	Обещание = ждать ВопросАсинх(ТекстВопроса,РежимДиалогаВопрос.ДаНет); 
	
	Если  Обещание = КодВозвратаДиалога.Нет Тогда
		возврат;
	КонецЕсли;
	
	ПерерасчетТабЧастиПоСкидке(Объект.Товары);
	ПерерасчетТабЧастиПоСкидке(Объект.Услуги);
	
КонецПроцедуры


